# URL base de la API Laravel CRABB (sin barra final)
# Ejemplo: https://api.crabbahia.com.ar/api
EXPO_PUBLIC_API_URL=

# URL base de la API TallerOK independiente (sin barra final)
# Ejemplo: https://tallerok-api.crabbahia.com.ar/api
EXPO_PUBLIC_TALLEROK_API_URL=https://tallerok-api.crabbahia.com.ar/api

# Ambiente: development | staging | production
EXPO_PUBLIC_APP_ENV=development

# Transcripción local de diagnóstico (opcional, solo dev)
# Ejemplo: http://192.168.0.9:8000
EXPO_PUBLIC_TRANSCRIBE_API_URL=
